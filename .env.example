# Copy this file to .env, then edit values if needed.

# Internal cache/profile name used by prismarine-auth. This is not your
# Microsoft account name or password.
BRIDGE_USERNAME=bedrock-realm-bridge

# Choose ONE of these, or leave all blank to pick from your joined/owned Realms list.
REALM_ID=
REALM_INVITE=
REALM_INDEX=0

# Optional exact Bedrock version. Leave blank to use bedrock-protocol's current default.
# If you get packet parser/version errors after connecting, set this to the exact version shown by Minecraft for Windows.
BEDROCK_VERSION=

# Realms sometimes does not answer bedrock-protocol's pre-connect RakNet ping even when the Realm is joinable.
# true = skip the advertisement ping and attempt the authenticated connection directly.
SKIP_PING=true

# Increase if your network/Realm is slow to respond.
CONNECT_TIMEOUT_MS=45000

# jsp-raknet avoids native build-tool issues on Windows. It may be slower than raknet-native.
RAKNET_BACKEND=jsp-raknet

# Packet/state logging.
LOG_PACKET_NAMES=true
LOG_PACKET_JSON=false
LOG_ALL_PACKETS=false
PACKET_LOG_DIR=packet-logs

# probe-realm exits after this many seconds after spawn. 0 = stay connected.
PROBE_SECONDS=90

# Java Edition LAN facade. This is the local server your Java client will see/join.
JAVA_LAN_HOST=0.0.0.0
JAVA_LAN_PORT=25565
JAVA_LAN_MOTD=JavaRock
# Leave blank to use the newest release bundled in minecraft-data.
JAVA_VERSION_NAME=
JAVA_PROTOCOL_VERSION=
# The supported gameplay path uses ViaProxy/ViaBedrock.
JAVA_FACADE_MODE=via-bedrock-relay
JAVA_COMPAT_MODE=viaproxy

# ViaProxy fronts the local Bedrock relay for Java Edition.
VIAPROXY_BEDROCK_TARGET_VERSION=Bedrock 1.26.30
BEDROCK_RELAY_UPSTREAM_VERSION=1.26.30

# Print raw Realm getAddress() data and normalized host/port.
DEBUG_REALM_ADDRESS=false

# Direct Bedrock server probe mode. This is for normal Bedrock Dedicated Servers/LAN servers, not modern Realms.
BEDROCK_SERVER_HOST=
BEDROCK_SERVER_PORT=19132

# Modern Realms may return a NetherNet GUID instead of a RakNet host. Leave this false/blank.
# true only reproduces the old DNS ENOTFOUND failure for debugging.
ALLOW_UUID_REALM_ENDPOINT=false
DEBUG_FATAL_STACK=false
